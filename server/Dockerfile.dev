FROM eclipse-temurin:25-jdk-jammy

RUN apt-get update \
    && apt-get install -y --no-install-recommends maven \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app/server

COPY server/pom.xml ./
RUN mvn dependency:go-offline -B -Pskip-frontend

COPY server/src ./src

EXPOSE 8080

CMD ["mvn", "spring-boot:run", "-Pskip-frontend"]
