{
  "name": "git-visualizer-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky .husky",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
