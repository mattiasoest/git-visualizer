# Image published by backend/scripts/publish-image.sh
GHCR_IMAGE=ghcr.io/mattiasoest/git-visualizer-backend:latest

# Host port mapped to the container
SERVER_PORT=8080

# Optional: higher GitHub API rate limits
GITHUB_TOKEN=

# Frontend origin allowed by the backend CORS policy
SPRING_WEB_CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
